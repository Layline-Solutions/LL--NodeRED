    {
        "id": "53a1cc0a3ab4b509",
        "type": "function",
        "z": "c6323837a7dd5adc",
        "name": "Auto-re-subscribe",
        "func": "const connected = msg.status?.text === \"connected\";\nconst lastSubscribed = flow.get(\"subscribed_ok\") || false;\nconst now = Date.now();\nconst lastTime = flow.get(\"subscribed_time\") || 0;\n\nif (connected) {\n    const timeSince = now - lastTime;\n\n    if (!lastSubscribed || timeSince > 10000) { // every 10s max\n        flow.set(\"subscribed_ok\", true);\n        flow.set(\"subscribed_time\", now);\n        return { payload: \"trigger\" };\n    }\n} else {\n    flow.set(\"subscribed_ok\", false);\n    flow.set(\"subscribed_time\", 0);\n}\nreturn null;",
