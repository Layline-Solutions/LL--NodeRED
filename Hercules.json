    {
        "id": "ea6fe53edbc33f7e",
        "type": "function",
        "z": "c6323837a7dd5adc",
        "name": "Handshake",
        "func": "function emit(msgObj, delay) {\n    setTimeout(() => {\n        node.send({ payload: msgObj });\n    }, delay);\n}\n\nconst variableMap = flow.get(\"variableMap\") || {};\nconst ids = Object.values(variableMap)\n    .map(entry => entry.goFreeId)\n    .filter(id => typeof id === \"number\");\n\nlet t = 0;\nemit({ Authentication: { id: 0 } }, t += 0);\nemit({ ProductIdReq: [] },      t += 200);\nemit({ FriendlyNameReq: [] },   t += 200);\nemit({ SettingInfoReq: [14,15,17,18,19,20,21] }, t += 200);\nemit({ EventReg: [5,10,21,24] }, t += 200);\nemit({ EventSet: [{ id: 21, action: \"request\" }] }, t += 200);\n\nconst dataReq = {\n    DataReq: ids.map(id => ({ id, repeat: true, inst: 0 }))\n};\nemit(dataReq, t += 200);\n\nreturn null;",
