    {
        "id": "80db955d5ea99d2a",
        "type": "function",
        "z": "c6323837a7dd5adc",
        "name": "Parse Data",
        "func": "if (typeof msg.payload === \"string\") {\n    try {\n        msg.payload = JSON.parse(msg.payload);\n    } catch (e) {\n        node.warn(\"Invalid JSON\");\n        return null;\n    }\n}\nconst data = msg.payload.Data;\nif (!Array.isArray(data)) return null;\n\nconst variableMap = flow.get(\"variableMap\") || {};\nfor (const item of data) {\n    if (item.valid && typeof item.id === \"number\" && typeof item.val === \"number\") {\n        for (const [expId, entry] of Object.entries(variableMap)) {\n            if (entry.goFreeId === item.id) {\n                flow.set(entry.name, item.val);\n                break;\n            }\n        }\n    }\n}\nflow.set(\"lastValidUpdate\", Date.now());\nreturn null;\n",
        "outputs": 0,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
